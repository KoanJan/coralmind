# LLM Configuration
# Copy this file to .env and fill in your actual API keys

# OpenAI compatible API
LLM_MODEL_ID=gpt-4
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MAX_TOKENS=8192

# Optional: Different LLM for planning (use stronger model)
# PLANNER_LLM_MODEL_ID=gpt-4
# PLANNER_LLM_BASE_URL=https://api.openai.com/v1
# PLANNER_LLM_API_KEY=your-api-key-here

# Optional: Different LLM for execution (use faster model)
# EXECUTOR_LLM_MODEL_ID=gpt-3.5-turbo
# EXECUTOR_LLM_BASE_URL=https://api.openai.com/v1
# EXECUTOR_LLM_API_KEY=your-api-key-here

# Database path (optional, defaults to ./coralmind.db)
# CORALMIND_DB_PATH=/path/to/coralmind.db
