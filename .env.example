# LLM Configuration
# Copy this file to .env and fill in your actual API keys

# Default LLM (required)
DEFAULT_MODEL_ID=gpt-4o-mini
DEFAULT_BASE_URL=https://api.openai.com/v1
DEFAULT_API_KEY=your-api-key-here
DEFAULT_MAX_TOKENS=8196

# Planner LLM (optional, uses default if not set)
# PLANNER_MODEL_ID=gpt-4o
# PLANNER_BASE_URL=https://api.openai.com/v1
# PLANNER_API_KEY=your-api-key-here

# Database path (optional, defaults to ./coralmind.db)
# CORALMIND_DB_PATH=/path/to/coralmind.db
